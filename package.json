{
  "name": "@sagtech-infra/ui",
  "version": "0.1.1",
  "description": "SagTech UI component library with Storybook",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./tokens": "./src/tokens/index.css",
    "./icons": {
      "import": "./dist/icons/index.js",
      "types": "./dist/icons/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src/tokens",
    "README.md"
  ],
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SagTech-infra/sagtech-ui.git"
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "tsup",
    "build-storybook": "storybook build",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build",
    "generate:tokens": "node scripts/generate-tokens.mjs",
    "prebuild": "node scripts/generate-tokens.mjs"
  },
  "peerDependencies": {
    "@dnd-kit/core": ">=6.0.0",
    "@dnd-kit/sortable": ">=8.0.0",
    "@dnd-kit/utilities": ">=3.0.0",
    "@tanstack/react-virtual": ">=3.0.0",
    "@tiptap/core": ">=2.0.0",
    "@tiptap/react": ">=2.0.0",
    "@tiptap/starter-kit": ">=2.0.0",
    "@xyflow/react": ">=12.0.0",
    "classnames": "^2.3.0",
    "framer-motion": ">=11.0.0",
    "next": ">=15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@dnd-kit/core": {
      "optional": true
    },
    "@dnd-kit/sortable": {
      "optional": true
    },
    "@dnd-kit/utilities": {
      "optional": true
    },
    "@tanstack/react-virtual": {
      "optional": true
    },
    "@tiptap/core": {
      "optional": true
    },
    "@tiptap/react": {
      "optional": true
    },
    "@tiptap/starter-kit": {
      "optional": true
    },
    "@xyflow/react": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "swiper": {
      "optional": true
    },
    "react-hook-form": {
      "optional": true
    },
    "react-international-phone": {
      "optional": true
    },
    "react-apexcharts": {
      "optional": true
    },
    "apexcharts": {
      "optional": true
    },
    "libphonenumber-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-virtual": "^3.13.24",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@tiptap/core": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@xyflow/react": "^12.10.2",
    "apexcharts": "^5.10.4",
    "classnames": "^2.5.1",
    "eslint": "^10.2.0",
    "framer-motion": "^12.38.0",
    "happy-dom": "^15.11.7",
    "libphonenumber-js": "^1.12.41",
    "next": "^16.2.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-apexcharts": "^2.1.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-international-phone": "^4.8.0",
    "storybook": "^10.3.4",
    "swiper": "^12.1.3",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@10.28.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}