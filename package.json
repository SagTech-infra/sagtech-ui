{
  "name": "@sagtech-infra/ui",
  "version": "1.8.0",
  "description": "SagTech UI component library with Storybook",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tokens": "./src/tokens/index.css",
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons/index.js"
    },
    "./3d": {
      "types": "./dist/3d/index.d.ts",
      "import": "./dist/3d/index.js",
      "require": "./dist/3d/index.cjs"
    },
    "./charts": {
      "types": "./dist/charts/index.d.ts",
      "import": "./dist/charts/index.js",
      "require": "./dist/charts/index.cjs"
    }
  },
  "files": [
    "dist",
    "src/tokens",
    "README.md",
    "docs/AI_MIGRATION_PROMPT.md"
  ],
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SagTech-infra/sagtech-ui.git"
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "tsup",
    "build-storybook": "storybook build",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build",
    "generate:tokens": "node scripts/generate-tokens.mjs",
    "check:contrast": "node scripts/check-contrast.mjs",
    "check:size": "size-limit",
    "prebuild": "node scripts/generate-tokens.mjs"
  },
  "peerDependencies": {
    "@dnd-kit/core": ">=6.0.0",
    "@dnd-kit/sortable": ">=8.0.0",
    "@dnd-kit/utilities": ">=3.0.0",
    "@react-three/drei": ">=9.100.0",
    "@react-three/fiber": ">=8.16.0",
    "@tanstack/react-virtual": ">=3.0.0",
    "@tiptap/core": ">=2.0.0",
    "@tiptap/extension-code-block-lowlight": ">=2.0.0",
    "@tiptap/extension-image": ">=2.0.0",
    "@tiptap/extension-mention": ">=2.0.0",
    "@tiptap/react": ">=2.0.0",
    "@tiptap/starter-kit": ">=2.0.0",
    "@tiptap/suggestion": ">=2.0.0",
    "@xyflow/react": ">=12.0.0",
    "classnames": "^2.3.0",
    "framer-motion": ">=11.0.0",
    "lowlight": ">=3.0.0",
    "next": ">=15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-force-graph-3d": ">=1.24.0",
    "react-resizable-panels": ">=2.0.0",
    "three": ">=0.160.0"
  },
