# ─────────────────────────────────────────────────────────────────────────────
# @sagtech-infra/ui — переменные окружения
#
# Это UI-библиотека компонентов (без бэкенда, БД и аутентификации).
# В рантайме самой библиотеки НИ ОДНА переменная окружения не читается.
# Единственная нужная переменная — токен для GitHub Packages npm-реестра.
# Скопируйте этот файл в `.env` и подставьте реальный токен.
# ─────────────────────────────────────────────────────────────────────────────

# GitHub Personal Access Token (classic) для аутентификации в npm.pkg.github.com.
# Используется в .npmrc при `pnpm install` (нужен scope read:packages),
# а для публикации пакета — write:packages.
# Создать: https://github.com/settings/tokens  →  Generate new token (classic)
# В CI этот токен подставляется автоматически из secrets.GITHUB_TOKEN — заполнять не нужно.
NODE_AUTH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
